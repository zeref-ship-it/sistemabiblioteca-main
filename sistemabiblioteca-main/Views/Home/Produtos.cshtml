@model List<sistemabiblioteca.Models.Produto>
@{
    ViewData["Title"] = "Acervo Arcano";
    Layout = "_Layout";
    var categorias = ViewBag.Categorias as List<string> ?? new List<string>();
    string? catAtual = ViewBag.CategoriaAtual;
    string? ordenar = ViewBag.Ordenar;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section class="hero">
    <p class="hero-label"><i class="bi bi-bag-heart-fill"></i></p>
    <h1>Acervo <span>Arcano de RPG</span></h1>
    <p>Grimórios, manuais de regras, bestiários e épicos de fantasia para sua próxima aventura</p>
    <form asp-action="Produtos" method="get" class="search-box">
        <input type="text" name="busca" value="@ViewBag.Busca" placeholder="Buscar por título, autor ou descrição..." />
        <button type="submit">🔮 Conjurar</button>
    </form>
</section>

<main>
    @if (TempData["MensagemCarrinho"] != null)
    {
        <div class="alert-cart"><i class="bi bi-bag-check-fill"></i> @TempData["MensagemCarrinho"] <a asp-controller="Carrinho" asp-action="Index">Ver mochila →</a></div>
    }

    <div class="layout-grid">
        <!-- ── Painel de Filtros ── -->
        <aside class="filtros-panel">
            <h3 class="filtros-title"><i class="bi bi-funnel-fill"></i> Filtros</h3>
            <form asp-action="Produtos" method="get">
                <input type="hidden" name="busca" value="@ViewBag.Busca" />

                <div class="filtro-group">
                    <label>Categoria</label>
                    <select name="categoria" class="filtro-control">
                        <option value="">Todas as categorias</option>
                        @foreach (var c in categorias)
                        {
                            if (c == catAtual)
                            {
                                <option value="@c" selected>@c</option>
                            }
                            else
                            {
                                <option value="@c">@c</option>
                            }
                        }
                    </select>
                </div>

                <div class="filtro-group">
                    <label>Faixa de Preço (R$)</label>
                    <div class="preco-row">
                        <input type="number" step="0.01" min="0" name="precoMin" value="@ViewBag.PrecoMin" placeholder="Mín" class="filtro-control" />
                        <span class="preco-sep">—</span>
                        <input type="number" step="0.01" min="0" name="precoMax" value="@ViewBag.PrecoMax" placeholder="Máx" class="filtro-control" />
                    </div>
                </div>

                <div class="filtro-group">
                    <label>Ordenar por</label>
                    <select name="ordenar" class="filtro-control">
                        <option value="" selected="@(string.IsNullOrEmpty(ordenar))">Nome (A-Z)</option>
                        <option value="nome_desc" selected="@(ordenar == "nome_desc")">Nome (Z-A)</option>
                        <option value="preco_asc" selected="@(ordenar == "preco_asc")">Menor preço</option>
                        <option value="preco_desc" selected="@(ordenar == "preco_desc")">Maior preço</option>
                    </select>
                </div>

                <button type="submit" class="btn-aplicar">Aplicar Filtros</button>
                <a asp-action="Produtos" class="btn-limpar-filtros">Limpar filtros</a>
            </form>
        </aside>

        <!-- ── Catálogo ── -->
        <div class="catalog-area">
            <div class="catalog-header">
                <h2 class="catalog-title">⚗️ Itens Disponíveis</h2>
                <span class="catalog-count"><i class="bi bi-tags-fill"></i> @(Model?.Count ?? 0) itens encontrados</span>
            </div>

            <div class="catalog-grid">
                @if (Model != null && Model.Any())
                {
                    @foreach (var produto in Model)
                    {
                        <article class="produto-card">
                            <div class="produto-capa">
                                @if (!string.IsNullOrEmpty(produto.ImagemUrl))
                                {
                                    <img src="@produto.ImagemUrl" alt="@produto.Nome" loading="lazy" />
                                }
                                else
                                {
                                    <span class="capa-emoji">📕</span>
                                }
                                <span class="produto-categoria">@produto.Categoria</span>
                            </div>
                            <div class="produto-body">
                                <h3 class="produto-nome">@produto.Nome</h3>
                                @if (!string.IsNullOrEmpty(produto.Autor))
                                {
                                    <p class="produto-autor"><i class="bi bi-feather"></i> @produto.Autor</p>
                                }
                                <p class="produto-descricao">@produto.Descricao</p>
                                <div class="produto-footer">
                                    <span class="produto-preco">@produto.Preco.ToString("C")</span>
                                    <form asp-controller="Carrinho" asp-action="Adicionar" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="produtoId" value="@produto.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn-add-cart"><i class="bi bi-bag-plus-fill"></i> Adicionar</button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <div class="catalog-empty">
                        <span class="empty-icon">📦</span>
                        <p>Nenhum artefato foi encontrado com esses filtros.</p>
                        <a asp-action="Produtos" class="btn-aplicar" style="display:inline-block;width:auto;margin-top:10px;">Ver todo o acervo</a>
                    </div>
                }
            </div>
        </div>
    </div>
</main>

<style>
    .hero {
        padding: 5rem 2rem; text-align: center;
        background: linear-gradient(rgba(18,12,31,0.80), rgba(18,12,31,0.88)), url('/images/produtos.png');
        background-size: cover; background-position: center; border-bottom: 1px solid #3a2a56;
    }
    .hero-label { display: inline-flex; align-items: center; gap: 6px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #ffb834; margin-bottom: 1rem; }
    .hero h1 { font-size: 2.6rem; color: #fff; margin-bottom: 0.8rem; }
    .hero h1 span { color: #ffb834; }
    .hero p { font-size: 1.05rem; color: #9c8eb9; max-width: 600px; margin: 0 auto 1.8rem; }
    .search-box { display: flex; max-width: 540px; margin: 0 auto; border: 2px solid #3a2a56; border-radius: 8px; overflow: hidden; transition: all 0.3s; }
    .search-box:focus-within { border-color: #ffb834; box-shadow: 0 0 12px rgba(255,184,52,0.2); }
    .search-box input { flex: 1; padding: 0.8rem 1.2rem; border: none; background: #1a1429; color: #fff; outline: none; font-size: 0.95rem; }
    .search-box input::placeholder { color: #9c8eb9; }
    .search-box button { background: #ffb834; color: #120c1f; border: none; padding: 0 1.4rem; font-weight: bold; cursor: pointer; transition: background 0.3s; }
    .search-box button:hover { background: #ffca64; }
    main { max-width: 1300px; margin: 0 auto; padding: 3rem 2rem; }
    .alert-cart { background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); color: #2ecc71; padding: 12px 16px; border-radius: 8px; margin-bottom: 24px; font-size: 0.9rem; }
    .alert-cart a { color: #ffb834; text-decoration: none; font-weight: 700; margin-left: 6px; }
    .layout-grid { display: grid; grid-template-columns: 260px 1fr; gap: 2rem; align-items: start; }

    /* Filtros */
    .filtros-panel { background: #1a1429; border: 1px solid #3a2a56; border-radius: 12px; padding: 1.6rem; position: sticky; top: 20px; }
    .filtros-title { font-size: 1.1rem; color: #ffb834; margin: 0 0 1.4rem; display: flex; align-items: center; gap: 8px; }
    .filtro-group { margin-bottom: 1.3rem; }
    .filtro-group label { display: block; font-size: 0.8rem; font-weight: 700; color: #e2daeb; margin-bottom: 8px; }
    .filtro-control { width: 100%; padding: 9px 12px; background: #120c1f; border: 1px solid #3a2a56; border-radius: 6px; color: #e2daeb; font-size: 0.86rem; outline: none; }
    .filtro-control:focus { border-color: #ffb834; }
    .preco-row { display: flex; align-items: center; gap: 8px; }
    .preco-sep { color: #9c8eb9; }
    .btn-aplicar { width: 100%; background: #ffb834; color: #120c1f; border: none; padding: 11px; border-radius: 6px; font-weight: 700; text-transform: uppercase; font-size: 0.82rem; letter-spacing: 0.04em; cursor: pointer; transition: all 0.2s; }
    .btn-aplicar:hover { background: #ffca64; }
    .btn-limpar-filtros { display: block; text-align: center; margin-top: 10px; color: #9c8eb9; text-decoration: none; font-size: 0.8rem; }
    .btn-limpar-filtros:hover { color: #ffb834; }

    /* Catálogo */
    .catalog-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.6rem; border-bottom: 1px solid #3a2a56; padding-bottom: 1rem; }
    .catalog-title { font-size: 1.4rem; color: #ffb834; margin: 0; }
    .catalog-count { font-size: 0.85rem; color: #9c8eb9; display: inline-flex; align-items: center; gap: 6px; }
    .catalog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.6rem; }
    .produto-card { background: #1a1429; border: 1px solid #3a2a56; border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.3s; }
    .produto-card:hover { transform: translateY(-5px); border-color: #ffb834; box-shadow: 0 8px 24px rgba(255,184,52,0.12); }
    .produto-capa { position: relative; height: 240px; background: linear-gradient(45deg,#251b3a,#3a2a56); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .produto-capa img { width: 100%; height: 100%; object-fit: cover; }
    .capa-emoji { font-size: 4rem; }
    .produto-categoria { position: absolute; top: 10px; left: 10px; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #ffb834; background: rgba(18,12,31,0.85); padding: 4px 10px; border-radius: 20px; border: 1px solid rgba(255,184,52,0.4); }
    .produto-body { flex: 1; padding: 1.2rem; display: flex; flex-direction: column; gap: 6px; }
    .produto-nome { font-size: 1.05rem; font-weight: 700; color: #fff; margin: 0; }
    .produto-autor { font-size: 0.78rem; color: #ffb834; margin: 0; display: flex; align-items: center; gap: 5px; }
    .produto-descricao { font-size: 0.84rem; color: #9c8eb9; margin: 4px 0 0; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .produto-footer { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: auto; padding-top: 14px; border-top: 1px solid #3a2a56; }
    .produto-preco { font-size: 1.15rem; font-weight: 700; color: #ffb834; white-space: nowrap; }
    .btn-add-cart { background: transparent; color: #ffb834; border: 1px solid #ffb834; padding: 7px 12px; border-radius: 6px; font-size: 0.78rem; font-weight: 700; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 5px; white-space: nowrap; }
    .btn-add-cart:hover { background: #ffb834; color: #120c1f; box-shadow: 0 0 10px rgba(255,184,52,0.4); }
    .catalog-empty { grid-column: 1 / -1; text-align: center; padding: 60px 20px; color: #9c8eb9; }
    .empty-icon { font-size: 2.5rem; display: block; margin-bottom: 12px; }
    @@media (max-width: 900px) { .layout-grid { grid-template-columns: 1fr; } .filtros-panel { position: static; } }
    @@media (max-width: 768px) { main { padding: 2rem 1.2rem; } .hero { padding: 3.5rem 1.5rem; } .hero h1 { font-size: 2rem; } }
</style>
