@model List<sistemabiblioteca.Models.Produto>
@{
    ViewData["Title"] = "Nossos Produtos";
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section class="hero">
    <p class="hero-label"><i class="bi bi-bag-heart-fill"></i> Loja da Biblioteca</p>
    <h1>Nossos <span>Produtos Arcanos</span></h1>
    <p>Encontre grimórios físicos, artefatos exclusivos e relíquias literárias</p>
    <form asp-action="Produtos" method="get" class="search-box">
        <input type="text" name="busca" placeholder="Pesquisar por nome ou descrição..." />
        <button type="submit">🔮 Conjurar</button>
    </form>
</section>

<main>
    <div class="catalog-header">
        <h2 class="catalog-title">⚗️ Itens Disponíveis</h2>
        <span class="catalog-count"><i class="bi bi-tags-fill"></i> @(Model?.Count ?? 0) produtos encontrados</span>
    </div>

    <div class="catalog-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var produto in Model)
            {
                <article class="produto-card">
                    <div class="produto-top-bar"></div>
                    <div class="produto-body">
                        <div class="produto-meta">
                            <span class="produto-categoria">@produto.Categoria</span>
                            <i class="bi bi-bookmark-star-fill star-icon"></i>
                        </div>
                        <h3 class="produto-nome">@produto.Nome</h3>
                        <p class="produto-descricao">@produto.Descricao</p>
                        <div class="produto-footer">
                            <span class="produto-preco">@produto.Preco.ToString("C")</span>
                            <a href="#" class="btn-detalhes">Ver Detalhes</a>
                        </div>
                    </div>
                </article>
            }
        }
        else
        {
            <div class="catalog-empty">
                <span class="empty-icon">📦</span>
                <p>Nenhum artefato foi encontrado no momento.</p>
            </div>
        }
    </div>
</main>

<style>
    .hero {
        padding: 5rem 2rem;
        text-align: center;
        background: linear-gradient(rgba(18,12,31,0.80), rgba(18,12,31,0.85)), url('/images/produtos.png');
        background-size: cover;
        background-position: center;
        border-bottom: 1px solid #3a2a56;
    }
    .hero-label {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em;
        text-transform: uppercase; color: #ffb834; margin-bottom: 1rem;
    }
    .hero h1 { font-size: 2.6rem; color: #fff; margin-bottom: 0.8rem; }
    .hero h1 span { color: #ffb834; }
    .hero p { font-size: 1.05rem; color: #9c8eb9; max-width: 560px; margin: 0 auto 1.8rem; }
    .search-box {
        display: flex; max-width: 500px; margin: 0 auto;
        border: 2px solid #3a2a56; border-radius: 8px; overflow: hidden; transition: all 0.3s;
    }
    .search-box:focus-within { border-color: #ffb834; box-shadow: 0 0 12px rgba(255,184,52,0.2); }
    .search-box input { flex: 1; padding: 0.8rem 1.2rem; border: none; background: #1a1429; color: #fff; outline: none; font-size: 0.95rem; }
    .search-box input::placeholder { color: #9c8eb9; }
    .search-box button { background: #ffb834; color: #120c1f; border: none; padding: 0 1.4rem; font-weight: bold; cursor: pointer; transition: background 0.3s; }
    .search-box button:hover { background: #ffca64; }
    main { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem; }
    .catalog-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid #3a2a56; padding-bottom: 1rem; }
    .catalog-title { font-size: 1.5rem; color: #ffb834; margin: 0; }
    .catalog-count { font-size: 0.85rem; color: #9c8eb9; display: inline-flex; align-items: center; gap: 6px; }
    .catalog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.8rem; }
    .produto-card { background: #1a1429; border: 1px solid #3a2a56; border-radius: 10px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.3s; }
    .produto-card:hover { transform: translateY(-5px); border-color: #ffb834; box-shadow: 0 8px 24px rgba(255,184,52,0.1); }
    .produto-top-bar { height: 4px; background: linear-gradient(90deg, #ffb834, #ffca64); }
    .produto-body { flex: 1; padding: 1.4rem; display: flex; flex-direction: column; gap: 8px; }
    .produto-meta { display: flex; align-items: center; justify-content: space-between; }
    .produto-categoria { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #ffb834; background: rgba(255,184,52,0.1); padding: 3px 10px; border-radius: 20px; border: 1px solid rgba(255,184,52,0.3); }
    .star-icon { color: #3a2a56; transition: color 0.2s; }
    .produto-card:hover .star-icon { color: #ffb834; }
    .produto-nome { font-size: 1.15rem; font-weight: 700; color: #fff; margin: 0; }
    .produto-descricao { font-size: 0.88rem; color: #9c8eb9; margin: 0; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .produto-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 12px; border-top: 1px solid #3a2a56; }
    .produto-preco { font-size: 1.2rem; font-weight: 700; color: #ffb834; }
    .btn-detalhes { display: inline-block; background: transparent; color: #ffb834; border: 1px solid #ffb834; padding: 5px 14px; border-radius: 5px; font-size: 0.8rem; font-weight: 600; text-decoration: none; transition: all 0.2s; }
    .btn-detalhes:hover { background: #ffb834; color: #120c1f; }
    .catalog-empty { grid-column: 1 / -1; text-align: center; padding: 60px 20px; color: #9c8eb9; }
    .empty-icon { font-size: 2.5rem; display: block; margin-bottom: 12px; }
    @@media (max-width: 768px) { main { padding: 2rem 1.2rem; } .hero { padding: 3.5rem 1.5rem; } .hero h1 { font-size: 2rem; } }
</style>