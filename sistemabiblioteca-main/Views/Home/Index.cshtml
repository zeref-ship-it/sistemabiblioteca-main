@model List<sistemabiblioteca.Models.Livro>
@{
    ViewData["Title"] = "Página Inicial";
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section class="hero-full-width">
    <div class="hero">
        <div class="hero-texture"></div>
        <div class="hero-content">
            <p class="hero-label"><i class="bi bi-book-half"></i> Biblioteca Digital</p>
            <h1 class="hero-title">A leitura é a chave para acessar o código-fonte do conhecimento.</h1>
            <p class="hero-desc">Explore nosso acervo totalmente gratuito</p>
            <form asp-action="Index" method="get" class="hero-search">
                <i class="bi bi-search search-icon"></i>
                <input type="text" name="busca" placeholder="Título, autor, tema ou palavra-chave..." class="hero-input" />
                <button type="submit" class="hero-btn">Buscar</button>
            </form>
        </div>
    </div>
</section>

<main class="catalog">
    <div class="catalog-header">
        <h2 class="catalog-title">Obras Gratuitas</h2>
        <span class="catalog-count"><i class="bi bi-collection"></i> @(Model?.Count ?? 0) títulos disponíveis</span>
    </div>

    <div class="catalog-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var livro in Model)
            {
                <article class="livro">
                    <div class="livro-spine"></div>
                    <div class="livro-body">
                        <div class="livro-top">
                            <span class="livro-tag">Acervo</span>
                            <i class="bi bi-bookmark-fill bookmark-icon"></i>
                        </div>
                        <h3 class="livro-titulo">@livro.Titulo</h3>
                        <div class="livro-divider"></div>
                        <div class="livro-autor-bloco">
                            <span class="livro-autor-label">por</span>
                            <span class="livro-autor-nome">@livro.Autor</span>
                        </div>
                    </div>
                </article>
            }
        }
        else
        {
            <div class="catalog-empty">
                <i class="bi bi-journal-x empty-icon"></i>
                <p>Nenhuma obra foi encontrada no momento.</p>
            </div>
        }
    </div>
</main>

<style>
    
    *, *::before, *::after { box-sizing: border-box; }

    body {
        margin: 0;
        background: #fbf9f4; 
        color: #2b2520;
        font-family: 'Georgia', 'Times New Roman', serif;
        -webkit-font-smoothing: antialiased;
    }


    .hero-full-width {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
    }


    .hero {
        position: relative;
        background-image: linear-gradient(rgba(0, 0, 0, 0.72), rgba(0, 0, 0, 0.72)), url('/images/biblioteca-bg.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        padding: 140px 40px 130px; 
        overflow: hidden;
        border-bottom: 4px solid #c5a059; 
        width: 100%;
    }

    .hero-texture {
        position: absolute;
        inset: 0;
        background-image: 
            radial-gradient(circle at 15% 85%, rgba(197, 160, 89, 0.05) 0%, transparent 50%),
            radial-gradient(circle at 85% 20%, rgba(255, 255, 255, 0.02) 0%, transparent 45%);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        max-width: 800px;
        margin: 0 auto;
        text-align: center;
        z-index: 1;
    }

    .hero-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #c5a059; 
        margin-bottom: 24px;
    }

    .hero-title {
        font-size: clamp(1.8rem, 4vw, 3rem);
        font-weight: 700;
        line-height: 1.25;
        color: #fbf9f4;
        margin: 0 0 20px;
        letter-spacing: -0.01em;
        text-shadow: 0 3px 10px rgba(0,0,0,0.6); 
    }

    .hero-desc {
        font-family: 'Georgia', serif;
        font-style: italic;
        font-size: 1.1rem;
        color: #e2edea; 
        margin: 0 0 36px;
        text-shadow: 0 2px 5px rgba(0,0,0,0.5);
    }

    /* Caixa de Busca Refinada */
    .hero-search {
        display: flex;
        align-items: center;
        background: #fbf9f4;
        border-radius: 8px;
        overflow: hidden;
        max-width: 560px;
        margin: 0 auto;
        box-shadow: 0 10px 30px rgba(0,0,0,0.35);
        border: 1px solid rgba(197, 160, 89, 0.3);
        padding-left: 16px;
    }

    .search-icon {
        color: #8c7e74;
        font-size: 1rem;
    }

    .hero-input {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        padding: 16px 12px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        font-size: 0.95rem;
        color: #2b2520;
    }

    .hero-input::placeholder { color: #a6988d; }

    .hero-btn {
        background: #c5a059; 
        color: #1e352f;
        border: none;
        padding: 18px 32px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }

    .hero-btn:hover { 
        background: #b38f47; 
        color: #fbf9f4;
    }

    /* ── Catálogo ── */
    .catalog {
        max-width: 1400px; 
        margin: 0 auto;
        padding: 60px 24px 80px;
    }

    .catalog-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 36px;
        border-bottom: 2px solid #1e352f;
        padding-bottom: 16px;
    }

    .catalog-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1e352f;
        margin: 0;
        letter-spacing: -0.01em;
    }

    .catalog-count {
        font-family: 'Segoe UI', system-ui, sans-serif;
        font-size: 0.85rem;
        color: #706255;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    
    .catalog-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(260px, 1fr));
        gap: 32px; 
    }

    
    @@media (max-width: 1200px) {
        .catalog-grid { grid-template-columns: repeat(3, minmax(240px, 1fr)); }
    }
    @@media (max-width: 900px) {
        .catalog-grid { grid-template-columns: repeat(2, minmax(200px, 1fr)); }
    }
    @@media (max-width: 550px) {
        .catalog-grid { grid-template-columns: 1fr; }
    }

    
    .livro {
        display: flex;
        background: #fff;
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(43, 37, 32, 0.05);
        border: 1px solid #e6ded2;
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s ease;
        cursor: pointer;
        min-height: 195px; 
    }

    .livro:hover {
        transform: translateY(-6px); 
        box-shadow: 0 16px 28px rgba(30, 53, 47, 0.15);
    }

    .livro-spine {
        width: 10px;
        flex-shrink: 0;
        background: linear-gradient(90deg, #142420 0%, #1e352f 60%, #29463f 100%); 
        border-right: 1px solid rgba(197, 160, 89, 0.2);
    }

    .livro-body {
        flex: 1;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        background: linear-gradient(135deg, #ffffff 80%, #faf6ee 100%);
    }

    .livro-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .livro-tag {
        font-family: 'Segoe UI', system-ui, sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #1e352f;
        background: #e9efe1; 
        padding: 3px 10px;
        border-radius: 4px;
    }

    .bookmark-icon {
        color: #ebdcb9;
        transition: color 0.2s;
    }

    .livro:hover .bookmark-icon {
        color: #c5a059; 
    }

    .livro-titulo {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1e352f; 
        margin: 0;
        line-height: 1.3;
        letter-spacing: -0.01em;
    }

    .livro-divider {
        height: 1px;
        background: #ebdcb9; 
        margin: 4px 0;
        width: 40px; 
    }

    .livro-autor-bloco {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: auto;
    }

    .livro-autor-label {
        font-family: 'Georgia', serif;
        font-size: 0.8rem;
        color: #8c7e74;
        font-style: italic;
    }

    .livro-autor-nome {
        font-family: 'Segoe UI', system-ui, sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        color: #54473c;
    }

    /* ── Estado Vazio ── */
    .catalog-empty {
        grid-column: 1 / -1;
        text-align: center;
        padding: 80px 20px;
        color: #8c7e74;
    }

    .empty-icon {
        font-size: 2.5rem;
        color: #ebdcb9;
        display: block;
        margin-bottom: 12px;
    }
</style>