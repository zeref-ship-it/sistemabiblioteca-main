<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dungeons Ebook - Biblioteca Arcana</title>
    <style>
        /* ==========================================================================
           1. CONFIGURAÇÕES GERAIS E PALETA DE CORES (RPG THEME)
           ========================================================================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --bg-principal: #120c1f; /* Roxo escuro/Masmorra mística */
            --bg-card: #1a1429;      /* Tom de pedra escuro para os blocos */
            --detalhe-ouro: #ffb834;  /* Ouro de tesouro/Luz de tocha */
            --texto-claro: #e2daeb;   /* Texto cor de pergaminho claro */
            --texto-mutado: #9c8eb9;  /* Texto secundário/Sombra */
            --borda-brilho: #3a2a56;  /* Borda mística mágica */
            --sucesso: #2ecc71;       /* Verde para itens disponíveis */
        }

        body {
            background-color: var(--bg-principal);
            color: var(--texto-claro);
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ==========================================================================
           2. CABEÇALHO E NAVEGAÇÃO
           ========================================================================== */
        header {
            background-color: rgba(26, 20, 41, 0.95);
            border-bottom: 2px solid var(--detalhe-ouro);
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: bold;
            color: var(--detalhe-ouro);
            text-shadow: 0 0 10px rgba(255, 184, 52, 0.3);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 2rem;
        }

        .nav-links a {
            color: var(--texto-claro);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s, text-shadow 0.3s;
        }

        .nav-links a:hover {
            color: var(--detalhe-ouro);
            text-shadow: 0 0 8px rgba(255, 184, 52, 0.5);
        }

        /* ==========================================================================
           3. SEÇÃO HERO (BANNER PRINCIPAL)
           ========================================================================== */
        .hero {
            padding: 6rem 2rem;
            text-align: center;
          background: linear-gradient(rgba(18, 12, 31, 0.75), rgba(18, 12, 31, 0.75)), 
            url('/images/index.png');
background-size: cover;
background-position: center;    
            border-bottom: 1px solid var(--borda-brilho);
        }

        .hero h1 {
            font-size: 3rem;
            color: #fff;
            margin-bottom: 1rem;
            letter-spacing: 1px;
        }

        .hero h1 span {
            color: var(--detalhe-ouro);
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--texto-mutado);
            max-width: 600px;
            margin: 0 auto 2rem auto;
        }

        /* Barra de Busca Mística */
        .search-box {
            display: flex;
            max-width: 500px;
            margin: 0 auto;
            border: 2px solid var(--borda-brilho);
            border-radius: 8px;
            overflow: hidden;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        .search-box:focus-within {
            border-color: var(--detalhe-ouro);
            box-shadow: 0 0 12px rgba(255, 184, 52, 0.2);
        }

        .search-box input {
            flex: 1;
            padding: 0.8rem 1.2rem;
            border: none;
            background-color: var(--bg-card);
            color: #fff;
            outline: none;
            font-size: 1rem;
        }

        .search-box input::placeholder {
            color: var(--texto-mutado);
        }

        .search-box button {
            background-color: var(--detalhe-ouro);
            color: var(--bg-principal);
            border: none;
            padding: 0 1.5rem;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: background 0.3s;
        }

        .search-box button:hover {
            background-color: #ffca64;
        }

        /* ==========================================================================
           4. CONTEÚDO PRINCIPAL (GRIDS)
           ========================================================================== */
        main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 4rem 2rem;
            flex: 1; /* Garante que o rodapé fique embaixo em telas grandes */
            width: 100%;
        }

        section {
            margin-bottom: 4rem;
        }

        section h2 {
            font-size: 2rem;
            color: var(--detalhe-ouro);
            margin-bottom: 2rem;
            border-left: 4px solid var(--detalhe-ouro);
            padding-left: 12px;
            letter-spacing: 0.5px;
        }

        /* Grid de Classes Literárias (Categorias) */
        .categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.5rem;
        }

        .category-card {
            background-color: var(--bg-card);
            border: 1px solid var(--borda-brilho);
            border-radius: 8px;
            padding: 2rem 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
        }

        .category-card:hover {
            transform: translateY(-5px);
            border-color: var(--detalhe-ouro);
            box-shadow: 0 5px 15px rgba(255, 184, 52, 0.1);
        }

        .category-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: block;
        }

        .category-card h3 {
            margin-bottom: 0.5rem;
            color: #fff;
        }

        .category-card p {
            font-size: 0.9rem;
            color: var(--texto-mutado);
        }

        /* Grid de Grimórios (Livros) */
        .books-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        .book-card {
            background-color: var(--bg-card);
            border: 1px solid var(--borda-brilho);
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: box-shadow 0.3s, transform 0.3s;
        }

        .book-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(58, 42, 86, 0.6);
        }

        .book-cover-placeholder {
            height: 200px;
            background: linear-gradient(45deg, #251b3a, #3a2a56);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            border-bottom: 2px solid var(--borda-brilho);
            user-select: none;
        }

        .book-info {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .book-title {
            font-size: 1.2rem;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        .book-author {
            font-size: 0.9rem;
            color: var(--detalhe-ouro);
            margin-bottom: 1rem;
        }

        .book-status {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1rem;
        }

        .badge-disponivel {
            background-color: rgba(46, 204, 113, 0.15);
            color: var(--sucesso);
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: bold;
            border: 1px solid rgba(46, 204, 113, 0.3);
        }

        .btn-action {
            background-color: transparent;
            border: 1px solid var(--detalhe-ouro);
            color: var(--detalhe-ouro);
            padding: 0.5rem 1.2rem;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s;
        }

        .btn-action:hover {
            background-color: var(--detalhe-ouro);
            color: var(--bg-principal);
            box-shadow: 0 0 10px rgba(255, 184, 52, 0.4);
        }

        /* ==========================================================================
           5. RODAPÉ (FOOTER)
           ========================================================================== */
        footer {
            background-color: #0b0714;
            border-top: 1px solid var(--borda-brilho);
            padding: 2rem;
            text-align: center;
            color: var(--texto-mutado);
            font-size: 0.9rem;
            margin-top: auto;
        }

        /* ==========================================================================
           6. RESPONSIVIDADE (MOBILE FIRST/ADAPTABILITY)
           ========================================================================== */
        @@media (max-width: 768px) {
            .nav-container {
                flex-direction: column;
                gap: 1.2rem;
                padding: 1.5rem;
            }
            
            .nav-links {
                gap: 1.2rem;
                flex-wrap: wrap;
                justify-content: center;
            }

            .hero {
                padding: 4rem 1.5rem;
            }

            .hero h1 {
                font-size: 2.2rem;
            }

            main {
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>
<body>

    <header>
        <div class="nav-container">
            <a href="#" class="logo">Biblioteca Arcana</a>

        </div>
    </header>

    <section class="hero">
        <h1>Explore a <span>Biblioteca Arcana</span></h1>
        <p>Desvende tomos antigos, gerencie seus pergaminhos emprestados e suba o nível do seu conhecimento.</p>
        
        <div class="search-box">
            <input type="text" placeholder="Buscar por título, autor ou feitiço...">
            <button>Conjurar</button>
        </div>
    </section>

    <main>

        <section>
            <h2>Classes Literárias</h2>
            <div class="categories-grid">
                <div class="category-card">
                    <span class="category-icon">🔮</span>
                    <h3>Magia & Ficção</h3>
                    <p>Mundos distantes e alta fantasia</p>
                </div>
                <div class="category-card">
                    <span class="category-icon">⚔️</span>
                    <h3>História & Batalhas</h3>
                    <p>Grandes crônicas da humanidade</p>
                </div>
                <div class="category-card">
                    <span class="category-icon">🧪</span>
                    <h3>Ciência & Alquimia</h3>
                    <p>Fórmulas e códigos do universo</p>
                </div>
                <div class="category-card">
                    <span class="category-icon">📜</span>
                    <h3>Poesia & Pergaminhos</h3>
                    <p>A arte dos bardos antigos</p>
                </div>
            </div>
        </section>

        <section>
            <h2>Grimórios Disponíveis</h2>
            <div class="books-grid">
                
                <div class="book-card">
                    <div class="book-cover-placeholder">📕</div>
                    <div class="book-info">
                        <h3 class="book-title">O Nome do Vento</h3>
                        <p class="book-author">Patrick Rothfuss</p>
                        <div class="book-status">
                            <span class="badge-disponivel">Disponível</span>
                            <button class="btn-action">Saquear</button>
                        </div>
                    </div>
                </div>

                <div class="book-card">
                    <div class="book-cover-placeholder">📘</div>
                    <div class="book-info">
                        <h3 class="book-title">O Hobbit</h3>
                        <p class="book-author">J.R.R. Tolkien</p>
                        <div class="book-status">
                            <span class="badge-disponivel">Disponível</span>
                            <button class="btn-action">Saquear</button>
                        </div>
                    </div>
                </div>

                <div class="book-card">
                    <div class="book-cover-placeholder">📙</div>
                    <div class="book-info">
                        <h3 class="book-title">O Caminho dos Reis</h3>
                        <p class="book-author">Brandon Sanderson</p>
                        <div class="book-status">
                            <span class="badge-disponivel">Disponível</span>
                            <button class="btn-action">Saquear</button>
                        </div>
                    </div>
                </div>

            </div>
        </section>

    </main>

    <footer>
        <p>&copy; 2026 Dungeons Ebook - Desenvolvido por um Mestre da Programação. Todos os direitos reservados.</p>
    </footer>

</body>
</html>