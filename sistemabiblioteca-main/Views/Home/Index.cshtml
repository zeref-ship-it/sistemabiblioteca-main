@model List<sistemabiblioteca.Models.Produto>
@{
    ViewData["Title"] = "Início";
    Layout = "_Layout";
    var busca = ViewBag.Busca as string;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section class="hero">
    
    <h1>Explore a <span>Biblioteca Arcana</span></h1>
    <p>Desvende tomos antigos de RPG, monte sua campanha e suba o nível do seu conhecimento. D&D, Pathfinder, fantasia épica e muito mais.</p>
    <form asp-action="Index" method="get" class="search-box">
        <input type="text" name="busca" value="@busca" placeholder="Buscar por título, autor ou categoria..." />
        <button type="submit">🔮 Conjurar</button>
    </form>
    <div class="hero-cta">
        <a asp-action="Produtos" class="btn-hero-primary">📚 Ver Acervo Completo</a>
        <a asp-controller="Carrinho" asp-action="Index" class="btn-hero-ghost">🎒 Minha Mochila</a>
    </div>
</section>

<main>
    <section>
        <h2>Classes Literárias</h2>
        <div class="categories-grid">
            <a asp-action="Produtos" asp-route-categoria="D&D" class="category-card">
                <span class="category-icon">🐉</span>
                <h3>Dungeons & Dragons</h3>
                <p>Manuais oficiais e aventuras</p>
            </a>
            <a asp-action="Produtos" asp-route-categoria="Pathfinder" class="category-card">
                <span class="category-icon">⚔️</span>
                <h3>Pathfinder</h3>
                <p>Regras e bestiários</p>
            </a>
            <a asp-action="Produtos" asp-route-categoria="Fantasia" class="category-card">
                <span class="category-icon">🔮</span>
                <h3>Fantasia Épica</h3>
                <p>Os grandes romances do gênero</p>
            </a>
            <a asp-action="Produtos" asp-route-categoria="Suplemento" class="category-card">
                <span class="category-icon">📜</span>
                <h3>Suplementos</h3>
                <p>Grimórios, atlas e tabelas</p>
            </a>
        </div>
    </section>

    <section>
        <div class="section-head">
            <h2>@(string.IsNullOrEmpty(busca) ? "Grimórios em Destaque" : $"Resultados para \"{busca}\"")</h2>
            <a asp-action="Produtos" class="ver-todos">Ver todos →</a>
        </div>

        <div class="books-grid">
            @if (Model != null && Model.Any())
            {
                @foreach (var livro in Model)
                {
                    <div class="book-card">
                        <div class="book-cover">
                            @if (!string.IsNullOrEmpty(livro.ImagemUrl))
                            {
                                <img src="@livro.ImagemUrl" alt="@livro.Nome" loading="lazy" />
                            }
                            else
                            {
                                <span class="cover-emoji">📕</span>
                            }
                            <span class="book-cat">@livro.Categoria</span>
                        </div>
                        <div class="book-info">
                            <h3 class="book-title">@livro.Nome</h3>
                            <p class="book-author">@livro.Autor</p>
                            <div class="book-status">
                                <span class="book-price">@livro.Preco.ToString("C")</span>
                                <form asp-controller="Carrinho" asp-action="Adicionar" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="produtoId" value="@livro.Id" />
                                    <input type="hidden" name="returnUrl" value="/" />
                                    <button type="submit" class="btn-action"><i class="bi bi-bag-plus-fill"></i> Saquear</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-msg">
                    <span>🗺️</span>
                    <p>Nenhum tesouro encontrado. Tente outra busca.</p>
                </div>
            }
        </div>
    </section>
</main>

<style>
    :root {
        --bg-card: #1a1429; --detalhe-ouro: #ffb834; --texto-claro: #e2daeb;
        --texto-mutado: #9c8eb9; --borda-brilho: #3a2a56; --sucesso: #2ecc71;
    }
    .hero {
        padding: 6rem 2rem 5rem; text-align: center;
        background: linear-gradient(rgba(18,12,31,0.78), rgba(18,12,31,0.85)), url('/images/index.png');
        background-size: cover; background-position: center; border-bottom: 1px solid var(--borda-brilho);
    }
    .hero-eyebrow { display: inline-block; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--detalhe-ouro); margin-bottom: 1.2rem; }
    .hero h1 { font-size: 3rem; color: #fff; margin-bottom: 1rem; letter-spacing: 1px; }
    .hero h1 span { color: var(--detalhe-ouro); text-shadow: 0 0 18px rgba(255,184,52,0.3); }
    .hero p { font-size: 1.15rem; color: var(--texto-mutado); max-width: 640px; margin: 0 auto 2rem; }
    .search-box { display: flex; max-width: 520px; margin: 0 auto; border: 2px solid var(--borda-brilho); border-radius: 8px; overflow: hidden; transition: all 0.3s; }
    .search-box:focus-within { border-color: var(--detalhe-ouro); box-shadow: 0 0 12px rgba(255,184,52,0.2); }
    .search-box input { flex: 1; padding: 0.85rem 1.2rem; border: none; background: var(--bg-card); color: #fff; outline: none; font-size: 1rem; }
    .search-box input::placeholder { color: var(--texto-mutado); }
    .search-box button { background: var(--detalhe-ouro); color: #120c1f; border: none; padding: 0 1.5rem; font-weight: bold; cursor: pointer; transition: background 0.3s; }
    .search-box button:hover { background: #ffca64; }
    .hero-cta { margin-top: 1.8rem; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn-hero-primary { background: var(--detalhe-ouro); color: #120c1f; text-decoration: none; padding: 12px 26px; border-radius: 6px; font-weight: 700; transition: all 0.2s; }
    .btn-hero-primary:hover { background: #ffca64; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(255,184,52,0.3); }
    .btn-hero-ghost { background: transparent; color: var(--detalhe-ouro); border: 1px solid var(--detalhe-ouro); text-decoration: none; padding: 12px 26px; border-radius: 6px; font-weight: 700; transition: all 0.2s; }
    .btn-hero-ghost:hover { background: var(--detalhe-ouro); color: #120c1f; }

    main { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; width: 100%; }
    section { margin-bottom: 4rem; }
    section h2 { font-size: 2rem; color: var(--detalhe-ouro); margin-bottom: 2rem; border-left: 4px solid var(--detalhe-ouro); padding-left: 12px; letter-spacing: 0.5px; }
    .section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .section-head h2 { margin-bottom: 0; }
    .ver-todos { color: var(--texto-mutado); text-decoration: none; font-size: 0.9rem; font-weight: 600; white-space: nowrap; }
    .ver-todos:hover { color: var(--detalhe-ouro); }

    .categories-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; }
    .category-card { background: var(--bg-card); border: 1px solid var(--borda-brilho); border-radius: 8px; padding: 2rem 1.5rem; text-align: center; cursor: pointer; transition: all 0.3s; text-decoration: none; display: block; }
    .category-card:hover { transform: translateY(-5px); border-color: var(--detalhe-ouro); box-shadow: 0 5px 15px rgba(255,184,52,0.1); }
    .category-icon { font-size: 2.5rem; margin-bottom: 1rem; display: block; }
    .category-card h3 { margin-bottom: 0.5rem; color: #fff; font-size: 1.15rem; }
    .category-card p { font-size: 0.9rem; color: var(--texto-mutado); margin: 0; }

    .books-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 2rem; }
    .book-card { background: var(--bg-card); border: 1px solid var(--borda-brilho); border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.3s; }
    .book-card:hover { transform: translateY(-4px); border-color: var(--detalhe-ouro); box-shadow: 0 8px 25px rgba(58,42,86,0.6); }
    .book-cover { position: relative; height: 260px; background: linear-gradient(45deg, #251b3a, #3a2a56); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .book-cover img { width: 100%; height: 100%; object-fit: cover; }
    .cover-emoji { font-size: 4rem; }
    .book-cat { position: absolute; top: 10px; left: 10px; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--detalhe-ouro); background: rgba(18,12,31,0.85); padding: 4px 10px; border-radius: 20px; border: 1px solid rgba(255,184,52,0.4); }
    .book-info { padding: 1.3rem; display: flex; flex-direction: column; flex-grow: 1; }
    .book-title { font-size: 1.1rem; color: #fff; margin-bottom: 0.3rem; }
    .book-author { font-size: 0.85rem; color: var(--detalhe-ouro); margin-bottom: 1rem; }
    .book-status { margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-top: 1rem; border-top: 1px solid var(--borda-brilho); gap: 8px; }
    .book-price { font-size: 1.15rem; font-weight: 700; color: var(--detalhe-ouro); white-space: nowrap; }
    .btn-action { background: transparent; border: 1px solid var(--detalhe-ouro); color: var(--detalhe-ouro); padding: 7px 14px; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 0.82rem; transition: all 0.3s; display: inline-flex; align-items: center; gap: 5px; white-space: nowrap; }
    .btn-action:hover { background: var(--detalhe-ouro); color: #120c1f; box-shadow: 0 0 10px rgba(255,184,52,0.4); }
    .empty-msg { grid-column: 1 / -1; text-align: center; padding: 50px; color: var(--texto-mutado); }
    .empty-msg span { font-size: 3rem; display: block; margin-bottom: 12px; }

    @@media (max-width: 768px) { .hero { padding: 4rem 1.5rem; } .hero h1 { font-size: 2.2rem; } main { padding: 2rem 1.5rem; } }
</style>
