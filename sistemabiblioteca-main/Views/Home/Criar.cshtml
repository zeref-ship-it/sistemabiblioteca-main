@model sistemabiblioteca.Models.Produto

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Cadastrar Novo Item</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Criar" method="post">
                        <div class="mb-3">
                            <label class="form-label">Nome do Produto/Serviço</label>
                            <input asp-for="Nome" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Categoria</label>
                            <select asp-for="Categoria" class="form-select">
                                <option value="Produto">Produto</option>
                                <option value="Serviço">Serviço</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Preço</label>
                            <input asp-for="Preco" type="number" step="0.01" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Salvar</button>
                        <a asp-action="Index" class="btn btn-link w-100 mt-2 text-muted">Cancelar</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>