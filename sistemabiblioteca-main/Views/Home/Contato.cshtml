@model sistemabiblioteca.Models.ContatoViewModel
@{
    ViewData["Title"] = "Contato";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section class="hero">
    <p class="hero-label"><i class="bi bi-envelope-paper-fill"></i> Pergaminho de Atendimento</p>
    <h1>Envie uma <span>Mensagem Arcana</span></h1>
    <p>Dúvidas, sugestões ou suporte? Nossos magos estão prontos para ajudar.</p>
</section>

<main class="contato-container">
    <div class="contato-wrapper">
        <div class="form-box">
            @if (TempData["MensagemSucesso"] != null)
            {
                <div class="alert-sucesso" role="alert">
                    <i class="bi bi-check-circle-fill"></i> @TempData["MensagemSucesso"]
                </div>
            }
            <form asp-action="Contato" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="form-group">
                    <label asp-for="Nome" class="form-label">Nome do Aventureiro</label>
                    <input asp-for="Nome" class="form-control" placeholder="Seu nome completo" />
                    <span asp-validation-for="Nome" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Cristal de Comunicação (E-mail)</label>
                    <input asp-for="Email" class="form-control" placeholder="exemplo@email.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Assunto" class="form-label">Assunto da Missão</label>
                    <input asp-for="Assunto" class="form-control" placeholder="Qual o motivo do contato?" />
                    <span asp-validation-for="Assunto" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Mensagem" class="form-label">Pergaminho da Mensagem</label>
                    <textarea asp-for="Mensagem" class="form-control" rows="5" placeholder="Escreva sua mensagem..."></textarea>
                    <span asp-validation-for="Mensagem" class="field-error"></span>
                </div>
                <button type="submit" class="btn-enviar">🔮 Enviar Pergaminho</button>
            </form>
        </div>

        <aside class="info-box">
            <h3 class="info-title">Canais Místicos</h3>
            <div class="info-divider"></div>
            <div class="info-item">
                <i class="bi bi-geo-alt-fill info-icon"></i>
                <div class="info-text"><h5>Localização da Torre</h5><p>SIN Trecho 1 SAI/SO Área 6580 - Guará, Brasília - DF, 71219-900</p></div>
            </div>
            <div class="info-item">
                <i class="bi bi-telephone-fill info-icon"></i>
                <div class="info-text"><h5>Orbe de Comunicação</h5><p>06140034137</p></div>
            </div>
            <div class="info-item">
                <i class="bi bi-envelope-open-fill info-icon"></i>
                <div class="info-text"><h5>Pombo-Correio Digital</h5><p>contato@biblioteca.com</p></div>
            </div>
            <div class="info-item">
                <i class="bi bi-clock-fill info-icon"></i>
                <div class="info-text"><h5>Horário da Masmorra</h5><p>Segunda a Domingo: 8h às 18h</p></div>
            </div>
        </aside>
    </div>
</main>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

<style>
    .hero {
        padding: 5rem 2rem;
        text-align: center;
        background: linear-gradient(rgba(18,12,31,0.80), rgba(18,12,31,0.85)), url('/images/contatos.png');
        background-size: cover;
        background-position: center;
        border-bottom: 1px solid #3a2a56;
    }
    .hero-label { display: inline-flex; align-items: center; gap: 6px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #ffb834; margin-bottom: 1rem; }
    .hero h1 { font-size: 2.6rem; color: #fff; margin-bottom: 0.8rem; }
    .hero h1 span { color: #ffb834; }
    .hero p { font-size: 1.05rem; color: #9c8eb9; max-width: 560px; margin: 0 auto; }
    .contato-container { max-width: 1100px; margin: 0 auto; padding: 3.5rem 2rem 5rem; }
    .contato-wrapper { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2.5rem; align-items: start; }
    .form-box { background: #1a1429; border: 1px solid #3a2a56; border-radius: 12px; padding: 2.5rem; }
    .info-box { background: #1a1429; border: 1px solid #3a2a56; border-radius: 12px; padding: 2rem 1.8rem; }
    .form-group { margin-bottom: 1.4rem; }
    .form-label { display: block; font-size: 0.88rem; font-weight: 700; color: #ffb834; margin-bottom: 6px; }
    .form-control { width: 100%; padding: 10px 14px; border: 1px solid #3a2a56; border-radius: 6px; background: #120c1f; color: #e2daeb; font-size: 0.9rem; outline: none; transition: all 0.2s; font-family: inherit; resize: vertical; }
    .form-control:focus { border-color: #ffb834; box-shadow: 0 0 0 3px rgba(255,184,52,0.12); }
    .form-control::placeholder { color: #9c8eb9; }
    .field-error { font-size: 0.8rem; color: #e74c3c; display: block; margin-top: 4px; }
    .btn-enviar { width: 100%; background: #ffb834; color: #120c1f; border: none; padding: 14px; border-radius: 6px; font-size: 0.95rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; transition: all 0.2s; }
    .btn-enviar:hover { background: #ffca64; transform: translateY(-1px); box-shadow: 0 4px 15px rgba(255,184,52,0.3); }
    .alert-sucesso { background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); color: #2ecc71; padding: 12px 16px; border-radius: 6px; margin-bottom: 20px; font-size: 0.9rem; }
    .info-title { font-size: 1.3rem; font-weight: 700; color: #ffb834; margin: 0 0 8px; }
    .info-divider { height: 2px; background: #ffb834; width: 36px; margin-bottom: 22px; opacity: 0.5; }
    .info-item { display: flex; gap: 14px; margin-bottom: 20px; }
    .info-icon { font-size: 1.2rem; color: #ffb834; margin-top: 2px; }
    .info-text h5 { font-size: 0.9rem; font-weight: 700; color: #e2daeb; margin: 0 0 3px; }
    .info-text p { font-size: 0.84rem; color: #9c8eb9; margin: 0; line-height: 1.5; }
    @@media (max-width: 850px) { .contato-wrapper { grid-template-columns: 1fr; gap: 2rem; } }
    @@media (max-width: 480px) { .form-box { padding: 1.5rem; } .hero { padding: 3.5rem 1.5rem; } }
</style>