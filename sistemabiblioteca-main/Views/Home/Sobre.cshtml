@{
    ViewData["Title"] = "Sobre Nós";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section class="hero">
    <p class="hero-label"><i class="bi bi-book-half"></i></p>
    <h1>Sobre a <span>Nossa Biblioteca</span></h1>
    <p>Transformando aventureiros em mestres do conhecimento desde 2025</p>
</section>

<main class="sobre-container">
    <section class="sobre-intro">
        <p class="lead-text">Bem-vindo à <strong>Biblioteca Arcana</strong>, seu portal para um universo de conhecimento e histórias épicas. Nossa missão é democratizar o acesso à leitura e ao aprendizado para todos os aventureiros.</p>
        <p class="normal-text">Acreditamos no poder transformador dos livros e na importância de fomentar a cultura e a educação. Nosso espaço é um convite à descoberta, ao estudo e ao lazer — com recursos modernos para conectar você ao próximo nível do conhecimento.</p>
    </section>

    <div class="sobre-divider"></div>

    <section class="sobre-mv">
        <div class="mv-card">
            <div class="mv-icon"><i class="bi bi-rocket-takeoff-fill"></i></div>
            <h4>Nossa Missão</h4>
            <p>Inovar na disseminação do conhecimento, integrando a comunidade e facilitando o acesso à cultura.</p>
        </div>
        <div class="mv-card">
            <div class="mv-icon"><i class="bi bi-eye-fill"></i></div>
            <h4>Nossa Visão</h4>
            <p>Ser reconhecida como um centro de excelência em cultura e educação, inspirando a paixão constante pelo aprendizado.</p>
        </div>
    </section>

    <section class="sobre-valores">
        <h3 class="secao-titulo">⚜️ Nossos Valores</h3>
        <div class="valores-grid">
            <div class="valor-card"><i class="bi bi-universal-access valor-icon"></i><h6>Acessibilidade</h6><p>Cultura para todos, sem barreiras.</p></div>
            <div class="valor-card"><i class="bi bi-cpu valor-icon"></i><h6>Inovação</h6><p>Tecnologia a serviço da leitura.</p></div>
            <div class="valor-card"><i class="bi bi-people-fill valor-icon"></i><h6>Comunidade</h6><p>Espaço de união e partilha.</p></div>
            <div class="valor-card"><i class="bi bi-heart-pulse-fill valor-icon"></i><h6>Respeito</h6><p>Valorização da diversidade de ideias.</p></div>
        </div>
    </section>

    <section class="sobre-cta">
        <p>Explore nossas coleções, participe de eventos e faça parte da nossa guilda.</p>
        <a href="/Home/Produtos" class="btn-explorar">⚔️ Explorar Acervo</a>
    </section>
</main>

<style>
    .hero { padding: 5rem 2rem; text-align: center; background: linear-gradient(rgba(18,12,31,0.85), #120c1f), radial-gradient(circle, rgba(58,42,86,0.4) 0%, rgba(18,12,31,1) 70%); border-bottom: 1px solid #3a2a56; }
    .hero-label { display: inline-flex; align-items: center; gap: 6px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #ffb834; margin-bottom: 1rem; }
    .hero h1 { font-size: 2.6rem; color: #fff; margin-bottom: 0.8rem; }
    .hero h1 span { color: #ffb834; }
    .hero p { font-size: 1.05rem; color: #9c8eb9; max-width: 560px; margin: 0 auto; }
    .sobre-container { max-width: 1000px; margin: 0 auto; padding: 3.5rem 2rem 5rem; }
    .sobre-intro { text-align: center; max-width: 800px; margin: 0 auto 3rem; }
    .lead-text { font-size: 1.2rem; line-height: 1.65; color: #e2daeb; margin-bottom: 16px; }
    .lead-text strong { color: #ffb834; }
    .normal-text { font-size: 1rem; line-height: 1.65; color: #9c8eb9; }
    .sobre-divider { height: 1px; background: #3a2a56; margin-bottom: 3rem; }
    .sobre-mv { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.8rem; margin-bottom: 3.5rem; }
    .mv-card { background: #1a1429; border: 1px solid #3a2a56; border-radius: 12px; padding: 2.2rem; text-align: center; transition: all 0.3s; }
    .mv-card:hover { transform: translateY(-5px); border-color: #ffb834; box-shadow: 0 8px 20px rgba(255,184,52,0.1); }
    .mv-icon { font-size: 2rem; color: #ffb834; margin-bottom: 14px; }
    .mv-card h4 { font-size: 1.3rem; font-weight: 700; color: #fff; margin: 0 0 10px; }
    .mv-card p { font-size: 0.92rem; color: #9c8eb9; line-height: 1.5; margin: 0; }
    .secao-titulo { text-align: center; font-size: 1.5rem; font-weight: 700; color: #ffb834; margin-bottom: 2rem; }
    .valores-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; margin-bottom: 3.5rem; }
    .valor-card { background: #1a1429; border: 1px solid #3a2a56; border-radius: 8px; padding: 1.6rem; text-align: center; transition: all 0.3s; }
    .valor-card:hover { border-color: #ffb834; }
    .valor-icon { font-size: 1.8rem; color: #ffb834; margin-bottom: 8px; display: inline-block; }
    .valor-card h6 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0 0 5px; }
    .valor-card p { font-size: 0.8rem; color: #9c8eb9; margin: 0; }
    .sobre-cta { text-align: center; padding: 16px 0 30px; }
    .sobre-cta p { color: #9c8eb9; font-style: italic; margin-bottom: 20px; }
    .btn-explorar { display: inline-block; background: #ffb834; color: #120c1f; text-decoration: none; padding: 13px 34px; border-radius: 6px; font-size: 0.88rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; transition: all 0.2s; }
    .btn-explorar:hover { background: #ffca64; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(255,184,52,0.3); }
    @@media (max-width: 992px) { .valores-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 768px) { .sobre-mv { grid-template-columns: 1fr; } .hero { padding: 3.5rem 1.5rem; } }
    @@media (max-width: 480px) { .valores-grid { grid-template-columns: 1fr; } }
</style>