@{
    ViewData["Title"] = "Sobre Nós";
}

<!-- Link para os ícones do Bootstrap (caso seu layout principal já não tenha) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Card Principal -->
            <div class="card shadow border-0 overflow-hidden rounded-4">
                <!-- Header com Gradiente Moderno -->
                <div class="bg-primary bg-gradient text-white text-center py-5">
                    <i class="bi bi-book-half display-4 mb-2"></i>
                    <h1 class="fw-bold mb-0">Sobre a Nossa Biblioteca</h1>
                    <p class="text-white-50 lead text-center px-3 mb-0">Transformando vidas através da leitura desde 2023</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <!-- Seção de Introdução -->
                    <div class="row align-items-center mb-5">
                        <div class="col-md-12">
                            <p class="lead text-muted lh-base">
                                Bem-vindo à <strong>Biblioteca do Conhecimento</strong>, seu portal para um universo de informações e histórias. 
                                Nossa missão é democratizar o acesso à leitura e ao aprendizado, oferecendo um acervo diversificado que atende a todos os gostos e idades.
                            </p>
                            <p class="text-muted">
                                Acreditamos no poder transformador dos livros e na importância de fomentar a cultura e a educação. 
                                Nosso espaço é um convite à descoberta, ao estudo e ao lazer, com ambientes acolhedores e recursos modernos para conectar você ao futuro.
                            </p>
                        </div>
                    </div>

                    <hr class="my-4 text-muted opacity-25">

                    <!-- Missão e Visão em Destaque -->
                    <div class="row g-4 mb-5 text-center">
                        <div class="col-md-6">
                            <div class="p-4 bg-light rounded-4 h-100 border border-light-subtle shadow-sm">
                                <div class="icon-square text-primary mb-3">
                                    <i class="bi bi-rocket-takeoff-fill fs-2"></i>
                                </div>
                                <h4 class="fw-bold text-dark">Nossa Missão</h4>
                                <p class="text-muted mb-0">Inovar na disseminação do conhecimento, integrando a comunidade e facilitando o acesso à cultura.</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-4 bg-light rounded-4 h-100 border border-light-subtle shadow-sm">
                                <div class="icon-square text-primary mb-3">
                                    <i class="bi bi-eye-fill fs-2"></i>
                                </div>
                                <h4 class="fw-bold text-dark">Nossa Visão</h4>
                                <p class="text-muted mb-0">Ser reconhecida como um centro de excelência em cultura e educação, inspirando a paixão constante pelo aprendizado.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Seção de Valores -->
                    <h4 class="text-center fw-bold text-dark mb-4">Nossos Valores</h4>
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-3">
                        
                        <div class="col">
                            <div class="card h-100 border-0 bg-light text-center p-3 shadow-sm rounded-3">
                                <i class="bi bi-universal-access text-primary fs-3 mb-2"></i>
                                <h6 class="fw-bold mb-1">Acessibilidade</h6>
                                <small class="text-muted">Cultura para todos, sem barreiras.</small>
                            </div>
                        </div>

                        <div class="col">
                            <div class="card h-100 border-0 bg-light text-center p-3 shadow-sm rounded-3">
                                <i class="bi bi-cpu text-primary fs-3 mb-2"></i>
                                <h6 class="fw-bold mb-1">Inovação</h6>
                                <small class="text-muted">Tecnologia a serviço da leitura.</small>
                            </div>
                        </div>

                        <div class="col">
                            <div class="card h-100 border-0 bg-light text-center p-3 shadow-sm rounded-3">
                                <i class="bi bi-people-fill text-primary fs-3 mb-2"></i>
                                <h6 class="fw-bold mb-1">Comunidade</h6>
                                <small class="text-muted">Espaço de união e partilha.</small>
                            </div>
                        </div>

                        <div class="col">
                            <div class="card h-100 border-0 bg-light text-center p-3 shadow-sm rounded-3">
                                <i class="bi bi-heart-pulse-fill text-primary fs-3 mb-2"></i>
                                <h6 class="fw-bold mb-1">Respeito</h6>
                                <small class="text-muted">Valorização da diversidade de ideias.</small>
                            </div>
                        </div>

                    </div>

                    <!-- Chamada para Ação Sutil -->
                    <div class="mt-5 pt-3 text-center">
                        <p class="text-secondary">Explore nossas coleções, participe de nossos eventos e faça parte da nossa comunidade.</p>
                        <a href="/Livros" class="btn btn-outline-primary btn-md px-4 rounded-pill fw-semibold">Explorar Acervo</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>