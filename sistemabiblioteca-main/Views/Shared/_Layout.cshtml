﻿<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - sistemabiblioteca</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/sistemabiblioteca.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* ═══════════════════════════════════════
           TEMA GLOBAL — BIBLIOTECA ARCANA
        ═══════════════════════════════════════ */
        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            background-color: #120c1f !important;
            color: #e2daeb !important;
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0;
            padding: 0;
        }

        /* Remove fundo branco do container do Bootstrap */
        .container, .container-fluid {
            background-color: transparent !important;
        }

        /* ── NAVBAR ── */
        .navbar {
            background: #0b0714 !important;
            border-bottom: 2px solid #ffb834 !important;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
            padding: 0.6rem 1rem;
        }

        .navbar-brand {
            color: #ffb834 !important;
            font-weight: 800;
            font-size: 1.15rem;
            letter-spacing: 0.03em;
        }

        .navbar-brand:hover { color: #ffca64 !important; }

        .nav-link {
            color: #c8bedd !important;
            font-weight: 500;
            transition: color 0.2s;
            padding: 0.5rem 0.9rem !important;
        }

        .nav-link:hover {
            color: #ffb834 !important;
        }

        /* Botão Sair */
        .btn-outline-secondary {
            color: #9c8eb9 !important;
            border-color: #3a2a56 !important;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .btn-outline-secondary:hover {
            background: #3a2a56 !important;
            color: #e2daeb !important;
        }

        /* Botão Área Administrativa */
        .btn-outline-primary {
            color: #ffb834 !important;
            border-color: #ffb834 !important;
            font-size: 0.85rem;
            font-weight: 700;
            transition: all 0.2s;
        }

        .btn-outline-primary:hover {
            background: #ffb834 !important;
            color: #120c1f !important;
            box-shadow: 0 4px 15px rgba(255,184,52,0.3);
        }

        /* Ícone hamburger mobile */
        .navbar-toggler {
            border-color: #3a2a56 !important;
        }

        .navbar-toggler-icon {
            filter: invert(1) sepia(1) saturate(2) hue-rotate(5deg);
        }

        /* ── MAIN CONTAINER ── */
        div.container > main {
            background: transparent !important;
        }

        /* ── FOOTER ── */
        footer.footer {
            background: #0b0714 !important;
            border-top: 1px solid #3a2a56 !important;
            color: #9c8eb9 !important;
            padding: 1.2rem 0;
            margin-top: 3rem;
        }

        footer.footer a {
            color: #ffb834 !important;
            text-decoration: none;
        }

        footer.footer a:hover {
            color: #ffca64 !important;
            text-decoration: underline;
        }

        /* ── SCROLLBAR CUSTOMIZADA ── */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0b0714; }
        ::-webkit-scrollbar-thumb { background: #3a2a56; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #ffb834; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    🔮 sistemabiblioteca
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Página Inicial</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Sobre">Sobre</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Produtos">Produtos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contato">Contato</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">Gerenciar Livros</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="CadastroCliente" asp-action="Index">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-secondary ms-2" asp-controller="Account" asp-action="Logout">Sair</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary ms-2" asp-controller="Account" asp-action="Login">⚔️ Área Administrativa</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            🔮 &copy; 2026 — Biblioteca Arcana &nbsp;|&nbsp;
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Política de Privacidade</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>