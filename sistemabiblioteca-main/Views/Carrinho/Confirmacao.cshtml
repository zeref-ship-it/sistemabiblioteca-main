@model sistemabiblioteca.Models.Pedido
@{
    ViewData["Title"] = "Pedido Confirmado";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<main class="confirm-container">
    <div class="confirm-card">
        <div class="confirm-icon">⚔️</div>
        <h1>Pacto Selado com Sucesso!</h1>
        <p class="confirm-sub">Seu pedido <strong>#@Model.Id</strong> foi registrado. Em breve nossos mensageiros entrarão em contato.</p>

        <div class="confirm-info">
            <div><span>Aventureiro</span><strong>@Model.NomeCliente</strong></div>
            <div><span>E-mail</span><strong>@Model.EmailCliente</strong></div>
            <div><span>Data</span><strong>@Model.DataPedido.ToString("dd/MM/yyyy HH:mm")</strong></div>
            <div><span>Status</span><strong class="status-badge">@Model.Status</strong></div>
        </div>

        <h3 class="itens-title">📜 Itens do Pedido</h3>
        <table class="itens-table">
            <thead>
                <tr><th>Item</th><th>Qtd</th><th>Unitário</th><th>Subtotal</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Itens)
                {
                    <tr>
                        <td>@item.NomeProduto</td>
                        <td>@item.Quantidade</td>
                        <td>@item.PrecoUnitario.ToString("C")</td>
                        <td>@item.Subtotal.ToString("C")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr><td colspan="3" class="total-label">Total</td><td class="total-value">@Model.Total.ToString("C")</td></tr>
            </tfoot>
        </table>

        <a asp-controller="Home" asp-action="Produtos" class="btn-voltar">🔮 Continuar Explorando o Acervo</a>
    </div>
</main>

<style>
    .confirm-container { max-width: 720px; margin: 0 auto; padding: 4rem 2rem 5rem; }
    .confirm-card { background: #1a1429; border: 1px solid #3a2a56; border-radius: 14px; padding: 2.5rem; text-align: center; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
    .confirm-icon { font-size: 3.5rem; margin-bottom: 12px; }
    .confirm-card h1 { color: #2ecc71; font-size: 1.8rem; margin: 0 0 10px; }
    .confirm-sub { color: #9c8eb9; margin-bottom: 28px; }
    .confirm-sub strong { color: #ffb834; }
    .confirm-info { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; text-align: left; background: #120c1f; border: 1px solid #3a2a56; border-radius: 8px; padding: 18px; margin-bottom: 28px; }
    .confirm-info span { display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: #9c8eb9; margin-bottom: 3px; }
    .confirm-info strong { color: #e2daeb; font-size: 0.95rem; }
    .status-badge { color: #ffb834 !important; }
    .itens-title { text-align: left; color: #ffb834; font-size: 1.1rem; margin: 0 0 14px; }
    .itens-table { width: 100%; border-collapse: collapse; text-align: left; margin-bottom: 28px; }
    .itens-table th { background: #0b0714; color: #ffb834; font-size: 0.75rem; text-transform: uppercase; padding: 10px 12px; border-bottom: 2px solid #ffb834; }
    .itens-table td { padding: 12px; border-bottom: 1px solid #3a2a56; color: #e2daeb; font-size: 0.9rem; }
    .total-label { text-align: right; font-weight: 700; color: #9c8eb9; }
    .total-value { font-weight: 700; color: #ffb834; font-size: 1.05rem; }
    .btn-voltar { display: inline-block; background: #ffb834; color: #120c1f; text-decoration: none; padding: 13px 30px; border-radius: 6px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; transition: all 0.2s; }
    .btn-voltar:hover { background: #ffca64; transform: translateY(-1px); box-shadow: 0 4px 15px rgba(255,184,52,0.3); }
    @@media (max-width: 560px) { .confirm-info { grid-template-columns: 1fr; } }
</style>
