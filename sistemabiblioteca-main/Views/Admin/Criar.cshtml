@model sistemabiblioteca.Models.Produto
@{
    ViewData["Title"] = "Forjar Nova Obra";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="form-page-container">
    <div class="form-card-box">
        <div class="form-top-bar"></div>
        <div class="form-card-header">
            <h2><i class="bi bi-journal-bookmark-fill"></i> Forjar Nova Obra</h2>
            <p>Preencha os campos abaixo com as informações detalhadas do item.</p>
        </div>
        <form asp-action="@ViewContext.RouteData.Values["action"]" method="post" class="classic-form">
            <div asp-validation-summary="ModelOnly" class="alert-erro"></div>
            <div class="form-group-custom">
                <label asp-for="Nome" class="form-label-custom">Título / Nome</label>
                <input asp-for="Nome" class="form-control-custom" placeholder="Digite o nome do produto ou título do livro..." />
                <span asp-validation-for="Nome" class="field-error"></span>
            </div>
            <div class="form-group-custom">
                <label asp-for="Descricao" class="form-label-custom">Descrição / Sinopse</label>
                <textarea asp-for="Descricao" class="form-control-custom" rows="4" placeholder="Escreva uma breve descrição ou resumo..."></textarea>
                <span asp-validation-for="Descricao" class="field-error"></span>
            </div>
            <div class="form-row-custom">
                <div class="form-group-custom">
                    <label asp-for="Preco" class="form-label-custom">Preço de Venda</label>
                    <div class="input-currency-wrapper">
                        <span class="currency-symbol">R$</span>
                        <input asp-for="Preco" class="form-control-custom padding-currency" placeholder="0,00" type="text" />
                    </div>
                    <span asp-validation-for="Preco" class="field-error"></span>
                </div>
                <div class="form-group-custom">
                    <label asp-for="Categoria" class="form-label-custom">Categoria / Gênero</label>
                    <input asp-for="Categoria" class="form-control-custom" placeholder="Ex: D&D, Pathfinder, Fantasia, Suplemento..." />
                    <span asp-validation-for="Categoria" class="field-error"></span>
                </div>
            </div>
            <div class="form-row-custom">
                <div class="form-group-custom">
                    <label asp-for="Autor" class="form-label-custom">Autor / Editora</label>
                    <input asp-for="Autor" class="form-control-custom" placeholder="Ex: Wizards of the Coast" />
                    <span asp-validation-for="Autor" class="field-error"></span>
                </div>
                <div class="form-group-custom">
                    <label asp-for="Estoque" class="form-label-custom">Estoque</label>
                    <input asp-for="Estoque" class="form-control-custom" type="number" min="0" placeholder="10" />
                    <span asp-validation-for="Estoque" class="field-error"></span>
                </div>
            </div>
            <div class="form-group-custom">
                <label asp-for="ImagemUrl" class="form-label-custom">Imagem (URL da capa)</label>
                <input asp-for="ImagemUrl" class="form-control-custom" placeholder="Ex: /images/livros/o-hobbit.jpg" />
                <span asp-validation-for="ImagemUrl" class="field-error"></span>
            </div>
            <div class="form-actions-bar">
                <button type="submit" class="btn-salvar"><i class="bi bi-check2-circle"></i> Forjar Registro</button>
                <a asp-action="Index" class="btn-cancelar">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }

<style>
    body { margin: 0; background: #120c1f; color: #e2daeb; font-family: 'Segoe UI', sans-serif; }
    .form-page-container { max-width: 800px; margin: 50px auto 80px; padding: 0 24px; }
    .form-card-box { background: #1a1429; border: 1px solid #3a2a56; border-radius: 10px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .form-top-bar { height: 5px; background: linear-gradient(90deg, #ffb834, #ffca64, #ffb834); }
    .form-card-header { padding: 35px 40px 20px; border-bottom: 1px solid #3a2a56; }
    .form-card-header h2 { font-size: 1.6rem; font-weight: 700; color: #ffb834; margin: 0 0 8px; display: flex; align-items: center; gap: 10px; }
    .form-card-header p { font-size: 0.9rem; color: #9c8eb9; margin: 0; }
    .classic-form { padding: 30px 40px 40px; }
    .form-group-custom { margin-bottom: 22px; flex: 1; }
    .form-row-custom { display: flex; gap: 24px; }
    .form-label-custom { display: block; font-size: 0.88rem; font-weight: 700; color: #ffb834; margin-bottom: 8px; }
    .form-control-custom { width: 100%; padding: 12px 16px; border: 1px solid #3a2a56; border-radius: 6px; background: #120c1f; color: #e2daeb; font-size: 0.95rem; outline: none; transition: all 0.2s; font-family: 'Segoe UI', sans-serif; resize: vertical; box-sizing: border-box; }
    .form-control-custom:focus { border-color: #ffb834; box-shadow: 0 0 0 3px rgba(255,184,52,0.12); }
    .form-control-custom::placeholder { color: #9c8eb9; }
    .input-currency-wrapper { position: relative; display: flex; align-items: center; }
    .currency-symbol { position: absolute; left: 14px; font-size: 0.95rem; font-weight: 600; color: #9c8eb9; pointer-events: none; }
    .padding-currency { padding-left: 42px; }
    .field-error { font-size: 0.8rem; color: #e74c3c; display: block; margin-top: 5px; }
    .alert-erro { background: rgba(231,76,60,0.1); border: 1px solid rgba(231,76,60,0.3); color: #e74c3c; padding: 10px 14px; border-radius: 6px; font-size: 0.88rem; margin-bottom: 16px; }
    .form-actions-bar { display: flex; align-items: center; gap: 16px; margin-top: 35px; padding-top: 25px; border-top: 1px solid #3a2a56; }
    .btn-salvar { background: #ffb834; color: #120c1f; border: none; padding: 14px 28px; border-radius: 6px; font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; }
    .btn-salvar:hover { background: #ffca64; transform: translateY(-1px); box-shadow: 0 4px 15px rgba(255,184,52,0.3); }
    .btn-cancelar { background: transparent; color: #9c8eb9; border: 1px solid #3a2a56; padding: 13px 24px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: all 0.2s; }
    .btn-cancelar:hover { background: #3a2a56; color: #e2daeb; }
    @@media (max-width: 600px) { .form-row-custom { flex-direction: column; gap: 0; } .classic-form { padding: 20px; } .form-card-header { padding: 25px 20px 15px; } .form-actions-bar { flex-direction: column; width: 100%; } .btn-salvar, .btn-cancelar { width: 100%; text-align: center; justify-content: center; } }
</style>