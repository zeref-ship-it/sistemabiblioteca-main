@model List<sistemabiblioteca.Models.Produto>
@{
    ViewData["Title"] = "Gerenciamento de Acervo";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section class="hero">
    <p class="hero-label"><i class="bi bi-shield-lock-fill"></i> Painel de Controle</p>
    <h1>Gerenciar <span>Acervo Arcano</span></h1>
    <p>Administre as obras, relíquias e artefatos do sistema</p>
</section>

<main class="admin-page-container">
    <div class="admin-card-box">
        <div class="admin-control-header">
            <div class="header-left">
                <h2 class="admin-panel-title"><i class="bi bi-collection-fill"></i> Lista de Livros</h2>
                <p class="admin-panel-subtitle">Gerencie as obras ativas no sistema</p>
            </div>
            <a asp-action="Criar" class="btn-novo-livro"><i class="bi bi-plus-lg"></i> Nova Obra</a>
        </div>

        <div class="admin-search-wrapper">
            <form method="get" class="admin-search-form">
                <div class="search-input-box">
                    <i class="bi bi-search search-inner-icon"></i>
                    <input type="text" name="busca" placeholder="Buscar por título, descrição ou categoria..." value="@Context.Request.Query["busca"]" />
                </div>
                <button type="submit" class="btn-filtrar">🔮 Buscar</button>
            </form>
        </div>

        <div class="table-responsive-custom">
            <table class="table-arcana">
                <thead>
                    <tr>
                        <th style="width:60px;">ID</th>
                        <th style="width:64px;">Capa</th>
                        <th>Título / Autor</th>
                        <th style="width:90px;">Estoque</th>
                        <th style="width:120px;">Preço</th>
                        <th style="width:140px;">Categoria</th>
                        <th style="width:180px;" class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="td-id">#@item.Id</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImagemUrl))
                                    {
                                        <img src="@item.ImagemUrl" alt="@item.Nome" class="capa-mini" />
                                    }
                                    else
                                    {
                                        <span class="capa-mini-emoji">📕</span>
                                    }
                                </td>
                                <td><span class="book-title-cell">@item.Nome</span><br /><span class="td-desc">@item.Autor</span></td>
                                <td>@item.Estoque</td>
                                <td class="td-price">@item.Preco.ToString("C")</td>
                                <td><span class="badge-category">@item.Categoria</span></td>
                                <td class="text-center">
                                    <div class="action-buttons-group">
                                        <a asp-action="Editar" asp-route-id="@item.Id" class="btn-action-edit" title="Editar"><i class="bi bi-pencil-fill"></i> Editar</a>
                                        <a asp-action="Excluir" asp-route-id="@item.Id" class="btn-action-delete" title="Excluir"><i class="bi bi-trash3-fill"></i> Excluir</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="table-empty-state">
                                <i class="bi bi-folder-x"></i>
                                <p>Nenhuma obra encontrada no acervo arcano.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</main>

<style>
    body { margin: 0; background: #120c1f; color: #e2daeb; font-family: 'Segoe UI', sans-serif; }

    /* Hero */
    .hero { padding: 5rem 2rem; text-align: center; background: linear-gradient(rgba(18,12,31,0.85), #120c1f), radial-gradient(circle, rgba(58,42,86,0.4) 0%, rgba(18,12,31,1) 70%); border-bottom: 1px solid #3a2a56; }
    .hero-label { display: inline-flex; align-items: center; gap: 6px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #ffb834; margin-bottom: 1rem; }
    .hero h1 { font-size: 2.6rem; color: #fff; margin-bottom: 0.8rem; }
    .hero h1 span { color: #ffb834; }
    .hero p { font-size: 1.05rem; color: #9c8eb9; max-width: 560px; margin: 0 auto; }

    /* Container */
    .admin-page-container { max-width: 1300px; margin: 50px auto 80px; padding: 0 24px; }
    .admin-card-box { background: #1a1429; border: 1px solid #3a2a56; border-radius: 10px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }

    /* Header do painel */
    .admin-control-header { display: flex; align-items: center; justify-content: space-between; padding: 35px 40px 25px; border-bottom: 1px solid #3a2a56; gap: 20px; }
    .admin-panel-title { font-size: 1.5rem; font-weight: 700; color: #ffb834; margin: 0 0 6px; display: flex; align-items: center; gap: 10px; }
    .admin-panel-subtitle { font-size: 0.88rem; color: #9c8eb9; margin: 0; }
    .btn-novo-livro { display: inline-flex; align-items: center; gap: 8px; background: #ffb834; color: #120c1f; padding: 12px 24px; border-radius: 6px; font-size: 0.88rem; font-weight: 700; text-transform: uppercase; text-decoration: none; letter-spacing: 0.03em; transition: all 0.2s; }
    .btn-novo-livro:hover { background: #ffca64; transform: translateY(-1px); box-shadow: 0 4px 15px rgba(255,184,52,0.3); }

    /* Barra de busca */
    .admin-search-wrapper { padding: 24px 40px; background: rgba(18,12,31,0.5); border-bottom: 1px solid #3a2a56; }
    .admin-search-form { display: flex; gap: 12px; max-width: 650px; }
    .search-input-box { position: relative; flex: 1; display: flex; align-items: center; }
    .search-inner-icon { position: absolute; left: 14px; color: #9c8eb9; font-size: 0.95rem; }
    .search-input-box input { width: 100%; padding: 11px 16px 11px 40px; border: 1px solid #3a2a56; border-radius: 6px; background: #120c1f; color: #e2daeb; font-size: 0.9rem; outline: none; transition: border-color 0.2s; font-family: 'Segoe UI', sans-serif; }
    .search-input-box input:focus { border-color: #ffb834; }
    .search-input-box input::placeholder { color: #9c8eb9; }
    .btn-filtrar { background: #3a2a56; color: #ffb834; border: 1px solid #3a2a56; padding: 0 24px; border-radius: 6px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-filtrar:hover { background: #ffb834; color: #120c1f; border-color: #ffb834; }

    /* Tabela */
    .table-responsive-custom { width: 100%; overflow-x: auto; }
    .table-arcana { width: 100%; border-collapse: collapse; text-align: left; }
    .table-arcana th { background: #0b0714; color: #ffb834; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 16px 24px; border: none; border-bottom: 2px solid #ffb834; }
    .table-arcana td { padding: 18px 24px; border-bottom: 1px solid #3a2a56; color: #e2daeb; font-size: 0.93rem; vertical-align: middle; }
    .table-arcana tbody tr:hover { background: rgba(58,42,86,0.25); }
    .td-id { font-size: 0.82rem; color: #9c8eb9; font-weight: 600; }
    .capa-mini { width: 42px; height: 56px; object-fit: cover; border-radius: 4px; border: 1px solid #3a2a56; }
    .capa-mini-emoji { font-size: 1.6rem; }
    .book-title-cell { font-weight: 700; color: #fff; }
    .td-desc { font-size: 0.87rem; color: #9c8eb9; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .td-price { font-weight: 700; color: #ffb834; }
    .badge-category { font-size: 0.73rem; font-weight: 700; color: #ffb834; background: rgba(255,184,52,0.1); padding: 4px 12px; border-radius: 20px; border: 1px solid rgba(255,184,52,0.3); display: inline-block; white-space: nowrap; }
    .action-buttons-group { display: flex; justify-content: center; gap: 10px; }
    .btn-action-edit, .btn-action-delete { font-size: 0.8rem; font-weight: 600; text-decoration: none; padding: 6px 14px; border-radius: 5px; display: inline-flex; align-items: center; gap: 6px; transition: all 0.2s; }
    .btn-action-edit { background: transparent; color: #ffb834; border: 1px solid #ffb834; }
    .btn-action-edit:hover { background: #ffb834; color: #120c1f; }
    .btn-action-delete { background: transparent; color: #e74c3c; border: 1px solid rgba(231,76,60,0.4); }
    .btn-action-delete:hover { background: #e74c3c; color: #fff; border-color: #e74c3c; }
    .table-empty-state { text-align: center; padding: 60px 20px !important; color: #9c8eb9; }
    .table-empty-state i { font-size: 2rem; margin-bottom: 8px; display: inline-block; }
    .table-empty-state p { margin: 0; font-size: 0.9rem; }

    @@media (max-width: 768px) {
        .admin-control-header { flex-direction: column; align-items: flex-start; padding: 25px 20px; }
        .btn-novo-livro { width: 100%; text-align: center; justify-content: center; }
        .admin-search-wrapper { padding: 20px; }
        .admin-search-form { flex-direction: column; width: 100%; }
        .btn-filtrar { padding: 12px; }
        .table-arcana th, .table-arcana td { padding: 12px 14px; }
        .hero h1 { font-size: 2rem; }
        .hero { padding: 3.5rem 1.5rem; }
    }
</style>