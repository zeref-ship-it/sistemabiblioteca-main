@model sistemabiblioteca.Models.Pedido
@{
    ViewData["Title"] = $"Pedido #{Model.Id}";
    var statusList = new[] { "Pendente", "Em Preparo", "Enviado", "Concluído", "Cancelado" };
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<section class="hero">
    <p class="hero-label"><i class="bi bi-receipt-cutoff"></i> Detalhes do Pedido</p>
    <h1>Pedido <span>#@Model.Id</span></h1>
    <p>Realizado em @Model.DataPedido.ToString("dd/MM/yyyy 'às' HH:mm")</p>
</section>

<main class="admin-page-container">
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert-sucesso"><i class="bi bi-check-circle-fill"></i> @TempData["MensagemSucesso"]</div>
    }

    <a asp-action="Pedidos" class="btn-voltar-link"><i class="bi bi-arrow-left"></i> Voltar para a lista</a>

    <div class="detalhe-grid">
        <div class="detalhe-card">
            <h3><i class="bi bi-person-fill"></i> Dados do Cliente</h3>
            <div class="info-row"><span>Nome</span><strong>@Model.NomeCliente</strong></div>
            <div class="info-row"><span>E-mail</span><strong>@Model.EmailCliente</strong></div>
            <div class="info-row"><span>Telefone</span><strong>@Model.TelefoneCliente</strong></div>
            <div class="info-row"><span>Endereço</span><strong>@(string.IsNullOrEmpty(Model.Endereco) ? "—" : Model.Endereco)</strong></div>
            <div class="info-row"><span>Observações</span><strong>@(string.IsNullOrEmpty(Model.Observacoes) ? "—" : Model.Observacoes)</strong></div>
        </div>

        <div class="detalhe-card">
            <h3><i class="bi bi-gear-fill"></i> Status do Pedido</h3>
            <p class="status-atual">Status atual: <span class="status-badge">@Model.Status</span></p>
            <form asp-action="AtualizarStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <label class="form-label-custom">Alterar status para:</label>
                <select name="status" class="form-control-custom">
                    @foreach (var s in statusList)
                    {
                        if (s == Model.Status)
                        {
                            <option value="@s" selected>@s</option>
                        }
                        else
                        {
                            <option value="@s">@s</option>
                        }
                    }
                </select>
                <button type="submit" class="btn-salvar mt-3"><i class="bi bi-check2-circle"></i> Atualizar Status</button>
            </form>
            <form asp-action="ExcluirPedido" method="post" onsubmit="return confirm('Tem certeza que deseja excluir este pedido?');" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn-excluir"><i class="bi bi-trash3-fill"></i> Excluir Pedido</button>
            </form>
        </div>
    </div>

    <div class="detalhe-card mt-4">
        <h3><i class="bi bi-box-seam-fill"></i> Itens do Pedido</h3>
        <table class="table-arcana">
            <thead>
                <tr><th>Item</th><th style="width:90px;">Qtd</th><th style="width:130px;">Unitário</th><th style="width:130px;">Subtotal</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Itens)
                {
                    <tr>
                        <td class="book-title-cell">@item.NomeProduto</td>
                        <td>@item.Quantidade</td>
                        <td>@item.PrecoUnitario.ToString("C")</td>
                        <td class="td-price">@item.Subtotal.ToString("C")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr><td colspan="3" class="total-label">Total do Pedido</td><td class="total-value">@Model.Total.ToString("C")</td></tr>
            </tfoot>
        </table>
    </div>
</main>

<style>
    body { margin: 0; background: #120c1f; color: #e2daeb; font-family: 'Segoe UI', sans-serif; }
    .hero { padding: 4rem 2rem; text-align: center; background: linear-gradient(rgba(18,12,31,0.85), #120c1f), radial-gradient(circle, rgba(58,42,86,0.4) 0%, rgba(18,12,31,1) 70%); border-bottom: 1px solid #3a2a56; }
    .hero-label { display: inline-flex; align-items: center; gap: 6px; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #ffb834; margin-bottom: 1rem; }
    .hero h1 { font-size: 2.4rem; color: #fff; margin-bottom: 0.6rem; }
    .hero h1 span { color: #ffb834; }
    .hero p { font-size: 1rem; color: #9c8eb9; margin: 0; }
    .admin-page-container { max-width: 1000px; margin: 40px auto 80px; padding: 0 24px; }
    .alert-sucesso { background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); color: #2ecc71; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; }
    .btn-voltar-link { display: inline-flex; align-items: center; gap: 6px; color: #9c8eb9; text-decoration: none; font-size: 0.88rem; margin-bottom: 20px; }
    .btn-voltar-link:hover { color: #ffb834; }
    .detalhe-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .detalhe-card { background: #1a1429; border: 1px solid #3a2a56; border-radius: 10px; padding: 1.8rem; }
    .detalhe-card h3 { font-size: 1.15rem; color: #ffb834; margin: 0 0 1.2rem; display: flex; align-items: center; gap: 10px; }
    .info-row { display: flex; flex-direction: column; gap: 2px; padding: 10px 0; border-bottom: 1px solid #3a2a56; }
    .info-row:last-child { border-bottom: none; }
    .info-row span { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: #9c8eb9; }
    .info-row strong { color: #e2daeb; font-size: 0.95rem; }
    .status-atual { color: #9c8eb9; margin-bottom: 18px; }
    .status-badge { font-size: 0.78rem; font-weight: 700; padding: 4px 14px; border-radius: 20px; color: #ffb834; background: rgba(255,184,52,0.12); border: 1px solid rgba(255,184,52,0.35); }
    .form-label-custom { display: block; font-size: 0.85rem; font-weight: 700; color: #ffb834; margin-bottom: 8px; }
    .form-control-custom { width: 100%; padding: 11px 14px; border: 1px solid #3a2a56; border-radius: 6px; background: #120c1f; color: #e2daeb; font-size: 0.93rem; outline: none; box-sizing: border-box; }
    .form-control-custom:focus { border-color: #ffb834; }
    .btn-salvar { background: #ffb834; color: #120c1f; border: none; padding: 12px 24px; border-radius: 6px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; }
    .btn-salvar:hover { background: #ffca64; }
    .btn-excluir { background: transparent; color: #e74c3c; border: 1px solid rgba(231,76,60,0.4); padding: 10px 20px; border-radius: 6px; font-weight: 600; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; }
    .btn-excluir:hover { background: #e74c3c; color: #fff; }
    .mt-3 { margin-top: 1rem; } .mt-4 { margin-top: 1.5rem; }
    .table-arcana { width: 100%; border-collapse: collapse; text-align: left; }
    .table-arcana th { background: #0b0714; color: #ffb834; font-size: 0.76rem; text-transform: uppercase; padding: 12px 16px; border-bottom: 2px solid #ffb834; }
    .table-arcana td { padding: 14px 16px; border-bottom: 1px solid #3a2a56; color: #e2daeb; font-size: 0.9rem; }
    .book-title-cell { font-weight: 700; color: #fff; }
    .td-price { font-weight: 700; color: #ffb834; }
    .total-label { text-align: right; font-weight: 700; color: #9c8eb9; }
    .total-value { font-weight: 700; color: #ffb834; font-size: 1.05rem; }
    @@media (max-width: 768px) { .detalhe-grid { grid-template-columns: 1fr; } }
</style>
